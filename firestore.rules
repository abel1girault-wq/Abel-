rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      // Designated admin email check
      return isEmailVerified() && request.auth.token.email == 'abel1.girault@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Pillar 2: Validation Blueprints
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'description', 'price', 'image', 'location', 'stock'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.description is string && data.description.size() <= 2000
        && data.price is number && data.price >= 0
        && data.image is string && data.image.matches('^https?://.*')
        && data.location is string && data.location.size() <= 100
        && data.stock is number && data.stock >= 0;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerName', 'customerEmail', 'customerPhone', 'location', 'items', 'total', 'status', 'createdAt'])
        && data.customerName is string && data.customerName.size() <= 100
        && data.customerEmail is string && data.customerEmail.size() <= 200
        && data.customerPhone is string && data.customerPhone.size() <= 30
        && data.location is string && data.location.size() <= 100
        && data.items is list && data.items.size() > 0
        && data.total is number && data.total >= 0
        && data.status in ['pending', 'processing', 'shipped', 'delivered']
        && data.createdAt == request.time;
    }

    // Collections
    match /products/{productId} {
      allow read: if true;
      allow write: if true; // Temporary: Allow admin actions via local password gate
    }

    match /orders/{orderId} {
      allow read: if true; // So admin can see orders without Google Auth
      allow create: if isValidId(orderId) && isValidOrder(incoming());
      allow update: if true; 
      allow delete: if true;
    }

    match /locations/{locId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
